      "item": [
        {
          "id": "017cdae6-1d32-418a-bb0f-4b58605de779",
          "name": "Run a search across a supported engine",
          "request": {
            "name": "Run a search across a supported engine",
            "description": {
              "content": "Runs a real-time search against the engine specified by the `engine` query parameter. Supports Google, Bing, YouTube, and many other engines. Engine-specific parameters are documented in the SerpApi engine reference.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "search"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "engine",
                  "value": "<string>",
                  "description": "(Required) Search engine identifier (e.g. google, bing, youtube)."
                },
                {
                  "disabled": false,
                  "key": "q",
                  "value": "<string>",
                  "description": "Search query (used by most engines except YouTube)."
                },
                {
                  "disabled": false,
                  "key": "search_query",
                  "value": "<string>",
                  "description": "Search query used by the YouTube engine."
                },
                {
                  "disabled": false,
                  "key": "api_key",
                  "value": "<string>",
                  "description": "SerpApi private key (may also be supplied via the apiKey security scheme)."
                },
                {
                  "disabled": false,
                  "key": "location",
                  "value": "<string>",
                  "description": "Geographic origin for the search."
                },
                {
                  "disabled": false,
                  "key": "gl",
                  "value": "<string>",
                  "description": "Two-letter country code."
                },
                {
                  "disabled": false,
                  "key": "hl",
                  "value": "<string>",
                  "description": "Two-letter language code."
                },
                {
                  "disabled": false,
                  "key": "device",
                  "value": "<string>",
                  "description": "Device type to emulate."
                },
                {
                  "disabled": false,
                  "key": "no_cache",
                  "value": "<boolean>",
                  "description": "Force fresh (uncached) results."
                },
                {
                  "disabled": false,
                  "key": "async",
                  "value": "<boolean>",
                  "description": "Submit asynchronously and retrieve results later."
                },
                {
                  "disabled": false,
                  "key": "output",
                  "value": "<string>",
                  "description": "Response format."
                }
              ],
              "variable": []
            },
